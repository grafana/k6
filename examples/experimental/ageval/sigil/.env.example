# Copy to .env and fill in. Load with:  set -a; . ./.env; set +a
# .env is gitignored — never commit real keys/tokens.

# LLM-as-judge (Anthropic-only). Required by every example that calls judge().
ANTHROPIC_API_KEY=

# --- Cloud examples (cloud/) -----------------------------------------------
# Your stack's Sigil app-plugin proxy base URL (no trailing slash):
#   https://<your-stack>/api/plugins/grafana-sigil-app/resources/query
SIGIL_BASE=
# A Grafana service-account token on that stack with the "Sigil Reader" role
# (RBAC action grafana-sigil-app.conversations:read).
ABT_SIGIL_TOKEN=

# --- Local examples (local/) -----------------------------------------------
# Defaults shown; override for your local agent + local Sigil.
# AGENT_URL=http://localhost:8000
# SIGIL_URL=http://localhost:8090
# SIGIL_TENANT=fake
